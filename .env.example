PORT=5174

# Company API that returns data.upload_url and data.s3_key. Keep its API key on
# this server: the browser calls /api/presign-pet-video instead of this URL directly.
S3_PRESIGN_URL=https://your-api-domain.example/s3/presigned-url/upload/
# When empty, the server falls back to ALGORITHM_API_KEY.
S3_PRESIGN_API_KEY=
S3_PRESIGN_AUTH_HEADER=X-API-Key
S3_PRESIGN_TIMEOUT_MS=15000
S3_UPLOAD_TIMEOUT_MS=45000
S3_UPLOAD_MAX_ATTEMPTS=3

# Public read URL used to turn the returned s3_key into the algorithm video URL.
S3_PUBLIC_BASE_URL=https://pemi-sticker.s3.us-east-1.amazonaws.com

# WebM clips are converted to H.264 MP4 before being sent to the algorithm.
# FFMPEG_PATH is optional when the bundled ffmpeg-static binary is available.
FFMPEG_PATH=
MAX_VIDEO_BYTES=31457280
VIDEO_DOWNLOAD_TIMEOUT_MS=30000
VIDEO_DOWNLOAD_MAX_ATTEMPTS=3
VIDEO_TRANSCODE_TIMEOUT_MS=60000

# Use this for local end-to-end testing before the real algorithm API is ready.
MOCK_ALGORITHM=true

# Required when MOCK_ALGORITHM is not true. The result URL must keep the
# {task_id} placeholder so the server can insert the task returned above.
ALGORITHM_CREATE_URL=https://pemiai.cn/app/pet_analyze/
ALGORITHM_RESULT_URL_TEMPLATE=https://pemiai.cn/app/pet_analyze/{task_id}/

# Poll every 3 seconds, with a 3-minute overall safety limit. These values are
# configurable even if the algorithm service does not prescribe limits yet.
ALGORITHM_POLL_INTERVAL_MS=3000
ALGORITHM_MAX_WAIT_MS=180000
ALGORITHM_REQUEST_TIMEOUT_MS=45000
ALGORITHM_REQUEST_MAX_ATTEMPTS=3

# Optional authentication settings for the algorithm service.
ALGORITHM_API_KEY=
ALGORITHM_AUTH_HEADER=X-API-Key
ALGORITHM_AUTH_SCHEME=
